{
  "compilerOptions": {
    "incremental": true,
    "target": "ESNext",
    "jsx": "preserve",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "module": "Node16",
    "moduleResolution": "node16",
    "paths": {
      "*": ["./*"],
      "@src/*": ["./src/*"],
      "@shared/*": ["./../shared/*"]
    },
    "resolveJsonModule": true,
    "strict": false,
    "noImplicitAny": false,
    "removeComments": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "../shared/**/*.ts"
  ]
}
